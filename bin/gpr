#! /bin/zsh

config_file=".aConfig"
default_main_branch="master"

# 定義關聯陣列：特定 remote URL 對應的主分支名稱
typeset -A main_branch_map
main_branch_map=(
  ["gogs@munuyk.com:sg-backend/rpc_modules.git"]="main"
)

remote_url=$(git remote get-url origin)
# 檢查遠端 URL 是否在對應表中，若有則覆蓋預設主分支
if [[ -n ${main_branch_map[$remote_url]} ]]; then
    default_main_branch=${main_branch_map[$remote_url]}
fi

# 檢查是否存在 .aConfig 檔案
if [ -f "$config_file" ]; then
  # 讀取 .aConfig 檔案中的內容
  config_value=$(grep "main_branch=" "$config_file" | cut -d'=' -f2-)

  # 檢查是否找到 main_branch= 指令
  if [ -n "$config_value" ]; then
    git open origin "$config_value" --suffix compare/"$config_value"..."$(git rev-parse --abbrev-ref HEAD)"
  else
    echo "未找到 main_branch= 指令，執行預設指令"
    git open origin "$default_main_branch" --suffix compare/"$default_main_branch"..."$(git rev-parse --abbrev-ref HEAD)"
  fi
else
  echo "未找到 $config_file ，執行預設指令"
  git open origin master --suffix compare/"$default_main_branch"..."$(git rev-parse --abbrev-ref HEAD)"
fi
