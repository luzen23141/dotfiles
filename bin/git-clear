#! /bin/zsh

if [[ $# -gt 0 && ($1 == "branch" || $1 == "b") ]]; then
  if [[ -n $2 ]]; then
    echo "預計刪除本地分支：$2"
    git branch -D "$2"
  else
    branches=$(git branch | grep -v '\*')
    if [[ -z $branches ]]; then
      echo "當前沒有任何分支"
    else
      echo "預計刪除以下本地分支："
      echo "$branches"
      git branch | grep -v '\*' | while IFS= read -r branch; do git branch -D "$branch"; done
    fi
  fi
elif  [[ $# -gt 0 && ($1 == "cache" || $1 == "c") ]]; then
  echo "開始刪除快取"
  size=$(du -sh .git | awk '{print $1}')
  printf "清理前 .git 目錄大小為：%s\n\n" "$size"

  # 清理未追蹤的檔案（Untracked Files）
  # -f force -d 遞迴所有目錄 -x 忽略 .gitignore 全部刪除
  git clean -fd
  git submodule foreach git clean -fd

  # 清理引用日誌（Reflog）
  git reflog expire --expire=now --all
  git submodule foreach git reflog expire --expire=now --all

  # 壓縮並優化倉庫（Garbage Collection）
  # 清理不再需要的物件並優化效能；--prune=now 立即刪除舊物件
  # --aggressive 更積極的優化，速度較慢，建議每幾百次 commit 執行一次
  git gc --prune=now --aggressive
  git submodule foreach git gc --prune=now --aggressive

  # 清理暫存區（Staging Area）
  # 取消所有已暫存的檔案（撤銷 git add）
  git reset
  git submodule foreach git reset

  # 清理合併衝突的殘留檔案
  # 解決合併衝突後，清理合併相關的備份與日誌
  git clean -f
  git submodule foreach git clean -f
  size=$(du -sh .git | awk '{print $1}')
  printf "\n清理後 .git 目錄大小為：%s\n" "$size"
else
  echo '用法: git clear branch [分支名] 或 git clear cache'
fi
