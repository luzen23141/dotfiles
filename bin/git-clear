#! /bin/zsh

# 確認破壞性操作。支援 -y/--yes；非 TTY 且未指定 -y 則失敗。
confirm_or_exit() {
  local prompt="$1"
  if [[ "$ASSUME_YES" -eq 1 ]]; then
    return 0
  fi
  if [[ ! -t 0 ]]; then
    echo "錯誤：非互動環境請加 -y / --yes" >&2
    exit 1
  fi
  printf "%s" "$prompt"
  read -r reply
  if [[ "$reply" != [yY] ]]; then
    echo "已取消"
    exit 0
  fi
}

ASSUME_YES=0
args=()
for arg in "$@"; do
  case "$arg" in
    -y|--yes) ASSUME_YES=1 ;;
    *) args+=("$arg") ;;
  esac
done
set -- "${args[@]}"

if [[ $# -gt 0 && ($1 == "branch" || $1 == "b" || $1 == "cache" || $1 == "c") ]]; then
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "錯誤：目前不在 Git 倉庫中。" >&2
    exit 1
  fi
fi

if [[ $# -gt 0 && ($1 == "branch" || $1 == "b") ]]; then
  if [[ -n $2 ]]; then
    echo "預計刪除本地分支：$2"
    confirm_or_exit "確認刪除？[y/N] "
    git branch -D "$2"
  else
    branches=$(git branch --format='%(refname:short)' | grep -v "^$(git branch --show-current)$")
    if [[ -z $branches ]]; then
      echo "當前沒有任何分支"
    else
      echo "預計刪除以下本地分支："
      echo "$branches" | sed 's/^/  /'
      confirm_or_exit "確認刪除以上分支？[y/N] "
      echo "$branches" | while IFS= read -r branch; do git branch -D "$branch"; done
    fi
  fi
elif [[ $# -gt 0 && ($1 == "cache" || $1 == "c") ]]; then
  size=$(du -sh .git | awk '{print $1}')
  echo "預計執行 git clear cache（僅 .git：reflog expire / gc --aggressive / reset）"
  echo "不會刪除工作區未追蹤檔案（不含 git clean）"
  printf "清理前 .git 目錄大小為：%s\n" "$size"
  confirm_or_exit "確認繼續？[y/N] "

  echo "開始清理 .git 快取"
  printf "清理前 .git 目錄大小為：%s\n\n" "$size"

  # 清理引用日誌（Reflog）
  git reflog expire --expire=now --all
  git submodule foreach git reflog expire --expire=now --all

  # 壓縮並優化倉庫（Garbage Collection）
  # 清理不再需要的物件並優化效能；--prune=now 立即刪除舊物件
  # --aggressive 更積極的優化，速度較慢，建議每幾百次 commit 執行一次
  git gc --prune=now --aggressive
  git submodule foreach git gc --prune=now --aggressive

  # 清理暫存區（Staging Area）
  # 取消所有已暫存的檔案（撤銷 git add）；不影響已追蹤的工作區修改
  git reset
  git submodule foreach git reset

  size=$(du -sh .git | awk '{print $1}')
  printf "\n清理後 .git 目錄大小為：%s\n" "$size"
else
  echo '用法: git clear branch [分支名] [-y] 或 git clear cache [-y]'
fi
