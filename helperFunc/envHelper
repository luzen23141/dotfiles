#!/bin/zsh

# 設定：指定 .env 檔案名稱
: "${DOTFILES:=$HOME/dotfiles}"
if [[ ! -d "$DOTFILES" ]]; then
  echo "錯誤：DOTFILES 目錄不存在：$DOTFILES" >&2
  return 1 2>/dev/null || exit 1
fi

ENV_FILE=".aConfig"

# 定義縮寫對應表
typeset -A shorter_key_map
shorter_key_map=(
  m "main_branch"
  a "mine_branch"
)

set_current_branch=("a" "m")

# 確保 ENV_FILE 存在（僅寫入路徑呼叫；讀取不應建立檔案）
ensure_env_exists() {
  if [[ ! -f "$ENV_FILE" ]]; then
    touch "$ENV_FILE"
  fi
}

# 跳脫 grep/sed 的正規表達式特殊字元
escape_regex() {
  printf '%s' "$1" | sed 's/[][\\.^$*+?(){}|/]/\\&/g'
}

# 跳脫 sed 替換字串的特殊字元
escape_sed_replacement() {
  printf '%s' "$1" | sed 's/[\\&]/\\&/g'
}

# 取得指定 key 的值，找不到時回傳預設值（檔案不存在不建立）
get_env_value() {
  local key=${shorter_key_map[$1]:-$1}
  local defaultValue=$2

  if [[ ! -f "$ENV_FILE" ]]; then
    echo "$defaultValue"
    return 0
  fi

  local escaped_key=$(escape_regex "$key")
  local value=$(grep -m 1 "^$escaped_key=" "$ENV_FILE" | cut -d '=' -f2-)

  if [[ -n $value ]]; then
    echo "$value"
  else
    echo "$defaultValue"
  fi
}

# 會包含key的整行資料（檔案不存在不建立）
get_env_contains() {
  [[ -f "$ENV_FILE" ]] || return 0

  local searchKey=$1
  local fullKey=${shorter_key_map[$searchKey]}
  local escaped_search_key=$(escape_regex "$searchKey")

  # 搜尋縮寫
  grep "^$escaped_search_key=" "$ENV_FILE"

  # 若有對應完整鍵名，一併搜尋
  if [[ -n $fullKey ]]; then
    local escaped_full_key=$(escape_regex "$fullKey")
    grep "^$escaped_full_key=" "$ENV_FILE"
  fi
}

# 設定指定 key 的值
set_env_value() {
  ensure_env_exists
  local key=${shorter_key_map[$1]:-$1}
  local value=$2
  local escaped_key=$(escape_regex "$key")
  local escaped_value=$(escape_sed_replacement "$value")

  # 確保檔案末尾有換行
  if [[ -s "$ENV_FILE" && -n "$(tail -c1 "$ENV_FILE")" ]]; then
    echo >> "$ENV_FILE"
  fi

  if grep -q "^$escaped_key=" "$ENV_FILE"; then
    sed -i '' "s/^$escaped_key=.*/$key=$escaped_value/" "$ENV_FILE"
  else
    echo "$key=$value" >> "$ENV_FILE"
  fi
}

# 列出 ENV_FILE 中所有 key-value（檔案不存在不建立）
list_env_values() {
  if [[ ! -f "$ENV_FILE" ]]; then
    return 0
  fi
  command cat "$ENV_FILE"
}

# 使用範例：
# get_env_value aaa "default_value"
# set_env_value aaa "new_value"
# list_env_values
